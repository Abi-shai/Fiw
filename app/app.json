{
  "expo": {
    "name": "Fiw",
    "slug": "fiw-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fiw",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F6B3D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fiw.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F6B3D"
      },
      "package": "com.fiw.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
